    <owl:NamedIndividual rdf:about="#Inyeccion_SQL_API"><rdf:type rdf:resource="#AMENAZA"/><EXPLOTAR rdf:resource="#Entrada_No_Validada"/><AFECTA rdf:resource="#Base_Datos_Tiempos"/></owl:NamedIndividual>
