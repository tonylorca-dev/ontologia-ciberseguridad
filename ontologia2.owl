    <owl:NamedIndividual rdf:about="#Base_Datos_Tiempos"><rdf:type rdf:resource="#ACTIVO"/></owl:NamedIndividual>

    <!-- INDIVIDUOS ADICIONALES PARA COMPLETAR LOS 20 -->
