    <owl:ObjectProperty rdf:about="#REQUIERE"><owl:inverseOf rdf:resource="#ES_REQUERIDO_POR"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#ES_REQUERIDO_POR"/>

    <!-- CLASES -->
    <owl:Class rdf:about="#ACTIVO"/><owl:Class rdf:about="#AMENAZA"/><owl:Class rdf:about="#CONTROL"/><owl:Class rdf:about="#POLITICA"/><owl:Class rdf:about="#VULNERABILIDAD"/>

    <!-- INDIVIDUOS CONECTADOS (EJEMPLO DE CADENA 1) -->
    <owl:NamedIndividual rdf:about="#Normativa_ISO27001"><rdf:type rdf:resource="#POLITICA"/><REQUIERE rdf:resource="#Firewall_Perimetral"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Firewall_Perimetral"><rdf:type rdf:resource="#CONTROL"/><MITIGAR rdf:resource="#Ataque_DDoS_Saturacion"/></owl:NamedIndividual>
