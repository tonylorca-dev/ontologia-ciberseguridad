    <owl:Ontology rdf:about="http://www.semanticweb.org/antonio/ontologies/2026/ciberseguridad"/>

    <!-- PROPIEDADES DE OBJETO E INVERSAS -->
    <owl:ObjectProperty rdf:about="#AFECTA"><owl:inverseOf rdf:resource="#ES_AFECTADO_POR"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#ES_AFECTADO_POR"/>

    <owl:ObjectProperty rdf:about="#EXPLOTAR"><owl:inverseOf rdf:resource="#ES_EXPLOTADO_POR"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#ES_EXPLOTADO_POR"/>

    <owl:ObjectProperty rdf:about="#MITIGAR"><owl:inverseOf rdf:resource="#ES_MITIGADO_POR"/></owl:ObjectProperty>
